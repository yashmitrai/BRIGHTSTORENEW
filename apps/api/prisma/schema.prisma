generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  RETAILER
  ADMIN
}

enum RetailerStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  COD
  WALLET
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum NotificationType {
  ORDER
  INVENTORY
  PROMOTION
  SYSTEM
}

enum AddressType {
  HOME
  WORK
  OTHER
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?        @unique
  passwordHash  String
  role          Role           @default(CUSTOMER)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  retailer      Retailer?
  addresses     Address[]
  orders        Order[]
  wishlist      Wishlist[]
  reviews       Review[]
  notifications Notification[]
  analytics     AnalyticsEvent[]

  @@index([role, isActive])
  @@map("users")
}

model Retailer {
  id             String         @id @default(cuid())
  userId         String         @unique
  businessName   String
  legalName      String?
  gstin          String?        @unique
  status         RetailerStatus @default(PENDING)
  commissionBps  Int            @default(750)
  approvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  stores         Store[]
  subscriptions  Subscription[]

  @@index([status, createdAt])
  @@map("retailers")
}

model Store {
  id             String       @id @default(cuid())
  retailerId     String
  name           String
  slug           String       @unique
  description    String?
  phone          String?
  email          String?
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  postalCode     String
  latitude       Decimal      @db.Decimal(9, 6)
  longitude      Decimal      @db.Decimal(9, 6)
  serviceRadiusKm Decimal      @default(5) @db.Decimal(5, 2)
  minimumOrderPaise Int        @default(0)
  deliveryFeePaise Int        @default(0)
  isActive       Boolean      @default(true)
  opensAt        String?
  closesAt       String?
  rating         Decimal      @default(0) @db.Decimal(3, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  retailer       Retailer     @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  inventories    Inventory[]
  storeOrders    StoreOrder[]
  reviews        Review[]

  @@index([retailerId, isActive])
  @@index([city, isActive])
  @@index([latitude, longitude])
  @@map("stores")
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  imageUrl  String?
  parentId  String?
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@index([parentId, sortOrder])
  @@map("categories")
}

model Product {
  id          String      @id @default(cuid())
  categoryId  String
  name        String
  slug        String      @unique
  brand       String?
  description String?
  unitLabel   String?
  barcode     String?     @unique
  imageUrls   String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category    @relation(fields: [categoryId], references: [id])
  inventories Inventory[]
  orderItems  OrderItem[]
  wishlist    Wishlist[]
  reviews     Review[]

  @@index([categoryId, isActive])
  @@index([name])
  @@map("products")
}

model Inventory {
  id          String   @id @default(cuid())
  storeId     String
  productId   String
  sku         String
  pricePaise  Int
  mrpPaise    Int
  costPaise   Int?
  stock       Int      @default(0)
  reservedStock Int    @default(0)
  lowStockAt  Int      @default(10)
  isAvailable Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@unique([storeId, sku])
  @@unique([storeId, productId])
  @@index([productId, isAvailable, pricePaise])
  @@index([storeId, stock])
  @@map("inventory")
}

model Address {
  id           String      @id @default(cuid())
  userId       String
  type         AddressType @default(HOME)
  label        String?
  recipientName String
  phone        String
  line1        String
  line2        String?
  landmark     String?
  city         String
  state        String
  postalCode   String
  latitude     Decimal?    @db.Decimal(9, 6)
  longitude    Decimal?    @db.Decimal(9, 6)
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId, isDefault])
  @@map("addresses")
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  userId         String
  addressId      String
  status         OrderStatus   @default(PENDING)
  subtotalPaise  Int
  deliveryPaise  Int           @default(0)
  discountPaise  Int           @default(0)
  platformFeePaise Int         @default(0)
  totalPaise     Int
  savingsPaise   Int           @default(0)
  idempotencyKey String?       @unique
  notes          String?
  placedAt       DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  address        Address       @relation(fields: [addressId], references: [id])
  storeOrders    StoreOrder[]
  payments       Payment[]

  @@index([userId, placedAt])
  @@index([status, placedAt])
  @@map("orders")
}

model StoreOrder {
  id             String      @id @default(cuid())
  orderId        String
  storeId        String
  status         OrderStatus @default(PENDING)
  subtotalPaise  Int
  deliveryPaise  Int         @default(0)
  totalPaise     Int
  acceptedAt     DateTime?
  readyAt        DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store          Store       @relation(fields: [storeId], references: [id])
  items          OrderItem[]

  @@unique([orderId, storeId])
  @@index([storeId, status, createdAt])
  @@map("store_orders")
}

model OrderItem {
  id             String     @id @default(cuid())
  storeOrderId   String
  productId      String
  inventoryId    String
  productName    String
  sku            String
  quantity       Int
  unitPricePaise Int
  mrpPaise       Int
  totalPaise     Int
  storeOrder     StoreOrder @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [productId], references: [id])
  inventory      Inventory  @relation(fields: [inventoryId], references: [id])

  @@index([productId])
  @@map("order_items")
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  provider    String
  providerRef String?       @unique
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  amountPaise Int
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@map("payments")
}

model Subscription {
  id             String             @id @default(cuid())
  retailerId     String
  plan           String
  status         SubscriptionStatus @default(TRIALING)
  amountPaise    Int
  interval       String             @default("month")
  providerRef    String?            @unique
  currentStart   DateTime
  currentEnd     DateTime
  cancelledAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  retailer       Retailer           @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@index([status, currentEnd])
  @@map("subscriptions")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  storeId   String?
  productId String?
  rating    Int
  title     String?
  body      String?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@map("reviews")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  name       String
  entityType String?
  entityId   String?
  properties Json?
  sessionId  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("analytics")
}
