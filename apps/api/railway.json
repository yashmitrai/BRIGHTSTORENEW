{
  "$schema": "https://railway.com/railway.schema.json",
  "build": { "builder": "NIXPACKS", "buildCommand": "cd ../.. && npm install && npm run db:generate && npm run build -w @brightstore/api" },
  "deploy": { "startCommand": "npm run start -w @brightstore/api", "healthcheckPath": "/health", "healthcheckTimeout": 120, "restartPolicyType": "ON_FAILURE", "restartPolicyMaxRetries": 10 }
}
